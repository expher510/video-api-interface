# -----------------------------
# Public App
# -----------------------------
# Base URL of your deployed app (used to build callback and poll links).
PUBLIC_API_BASE_URL="https://your-domain.vercel.app"

# -----------------------------
# Firebase Admin (Server only)
# -----------------------------
# Generate these values from a Firebase service account with Firestore access.
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Use "(default)" unless you intentionally created a named Firestore DB.
FIREBASE_DATABASE_ID="(default)"

# -----------------------------
# Redis (Upstash REST)
# -----------------------------
REDIS_REST_URL="https://your-redis-instance.upstash.io"
REDIS_REST_TOKEN="your-upstash-rest-token"

# -----------------------------
# GitHub Repository Dispatch
# -----------------------------
# Format: owner/repository
GITHUB_REPO="expher510/meta-ai-automation"
GITHUB_TOKEN="ghp_your_token_with_repo_scope"
GITHUB_EVENT_TYPE="generate_video"

# -----------------------------
# Internal Security
# -----------------------------
# Used by /api/set-cookies endpoint to protect cookie uploads.
ADMIN_API_TOKEN="replace-with-a-long-random-token"

# Used by /api/received-video endpoint to validate callback source.
RECEIVED_VIDEO_SECRET="replace-with-another-long-random-token"
# Optional: lock callback to one source IP (leave empty to disable).
RECEIVED_VIDEO_ALLOWED_IP=""
